async def cancel(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Отменить текущую операцию"""
    await update.message.reply_text(
        "❌ Операция отменена.",
        reply_markup=InlineKeyboardMarkup([
            [InlineKeyboardButton("◀️ Главное меню", callback_data='back_to_menu')]
        ])
    )
    context.user_data.clear()
    return CHOOSING_ACTION

def main():
    """Запуск бота"""
    application = Application.builder().token(BOT_TOKEN).build()
    
    # Conversation handler
    conv_handler = ConversationHandler(
        entry_points=[CommandHandler('start', start)],
        states={
            CHOOSING_ACTION: [CallbackQueryHandler(button_handler)],
            ENTERING_NFT: [MessageHandler(filters.TEXT & ~filters.COMMAND, receive_nft_name)],
            ENTERING_PRICE: [MessageHandler(filters.TEXT & ~filters.COMMAND, receive_nft_price)],
            ENTERING_DESCRIPTION: [MessageHandler(filters.TEXT & ~filters.COMMAND, receive_nft_description)],
        },
        fallbacks=[CommandHandler('cancel', cancel)],
    )
    
    application.add_handler(conv_handler)
    
    logger.info("🤖 Бот запущен!")
    application.run_polling(allowed_updates=Update.ALL_TYPES)

if __name__ == '__main__':
    main()
