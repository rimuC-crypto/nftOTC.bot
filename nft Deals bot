)

logging.basicConfig(level=logging.INFO)
logger = logging.getLogger(__name__)

BOT_TOKEN = os.getenv("BOT_TOKEN", "8378557461:AAGEAo5D1-BCTd_drnvPMQ1Gitx+M7Qet5aw")
SUPPORT_USERNAME = "otcmarketHelper"

# Состояния разговора
CHOOSING_ACTION, ENTERING_NFT, ENTERING_PRICE, ENTERING_DESCRIPTION = range(4)

# Временное хранилище данных пользователей
user_nfts = {}
user_deals = {}

async def start(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Обработчик команды /start"""
    keyboard = [
        [InlineKeyboardButton("🎨 Мои NFT", callback_data='my_nfts')],
        [InlineKeyboardButton("➕ Добавить NFT", callback_data='add_nft')],
        [InlineKeyboardButton("💼 Мои сделки", callback_data='my_deals')],
        [InlineKeyboardButton("❓ Помощь", callback_data='help')]
    ]
    reply_markup = InlineKeyboardMarkup(keyboard)
    
    await update.message.reply_text(
        "👋 Добро пожаловать в NFT OTC Bot!\n\n"
        "Я помогу вам управлять NFT и проводить OTC сделки.\n"
        "Выберите действие:",
        reply_markup=reply_markup
    )
    return CHOOSING_ACTION

async def button_handler(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Обработчик нажатий на кнопки"""
    query = update.callback_query
    await query.answer()
    
    user_id = query.from_user.id
    
    if query.data == 'my_nfts':
        return await show_my_nfts(update, context)
    elif query.data == 'add_nft':
        return await add_nft_start(update, context)
    elif query.data == 'my_deals':
        return await show_my_deals(update, context)
    elif query.data == 'help':
        return await show_help(update, context)
    elif query.data == 'back_to_menu':
        return await back_to_menu(update, context)
    elif query.data.startswith('nft_'):
        return await view_nft_details(update, context)
    elif query.data.startswith('sell_'):
        return await sell_nft(update, context)
    elif query.data.startswith('delete_'):
        return await delete_nft(update, context)
    
    return CHOOSING_ACTION

async def show_my_nfts(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Показать список NFT пользователя"""
    query = update.callback_query
    user_id = query.from_user.id
    
    if user_id not in user_nfts or not user_nfts[user_id]:
        await query.edit_message_text(
            "📭 У вас пока нет NFT.\n\n"
            "Добавьте свой первый NFT с помощью кнопки ниже!",
            reply_markup=InlineKeyboardMarkup([
                [InlineKeyboardButton("➕ Добавить NFT", callback_data='add_nft')],
                [InlineKeyboardButton("◀️ Назад", callback_data='back_to_menu')]
            ])
        )
        return CHOOSING_ACTION
    
    keyboard = []
    for idx, nft in enumerate(user_nfts[user_id]):
        keyboard.append([InlineKeyboardButton(
            f"🎨 {nft['name']}", 
            callback_data=f'nft_{idx}'
        )])
    
    keyboard.append([InlineKeyboardButton("◀️ Назад", callback_data='back_to_menu')])
    
    await query.edit_message_text(
        "🎨 Ваши NFT:\n\nВыберите NFT для просмотра деталей:",
        reply_markup=InlineKeyboardMarkup(keyboard)
    )
    return CHOOSING_ACTION

async def view_nft_details(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Показать детали конкретного NFT"""
    query = update.callback_query
    user_id = query.from_user.id
    
    # Исправленная обработка callback_data
    nft_index = int(query.data.split('_')[1])
    
    # Проверка существования данных
    if user_id not in user_nfts or nft_index >= len(user_nfts[user_id]):
        await query.answer("❌ NFT не найден!", show_alert=True)
        return CHOOSING_ACTION
    
    nft_data = user_nfts[user_id][nft_index]
    
    message = (
        f"🎨 *{nft_data['name']}*\n\n"
        f"💰 Цена: {nft_data['price']} TON\n"
        f"📝 Описание: {nft_data['description']}\n"
        f"🆔 ID: `{nft_data['id']}`\n"
        f"📅 Добавлено: {nft_data['date']}"
    )
    
    keyboard = [
        [InlineKeyboardButton("💼 Продать", callback_data=f"sell_{nft_index}")],
        [InlineKeyboardButton("🗑 Удалить", callback_data=f"delete_{nft_index}")],
        [InlineKeyboardButton("◀️ К списку NFT", callback_data='my_nfts')]
    ]
    
    await query.edit_message_text(
        message,
        reply_markup=InlineKeyboardMarkup(keyboard),
        parse_mode='Markdown'
    )
    return CHOOSING_ACTION

async def add_nft_start(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Начать процесс добавления NFT"""
    query = update.callback_query
    
    await query.edit_message_text(
        "📝 *Добавление нового NFT*\n\n"
        "Введите название вашего NFT:",
        parse_mode='Markdown'
    )
    return ENTERING_NFT

async def receive_nft_name(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Получить название NFT"""
    context.user_data['nft_name'] = update.message.text
    
    await update.message.reply_text(
        "💰 Отлично!\n\n"
        "Теперь введите цену в TON:"
    )
    return ENTERING_PRICE

async def receive_nft_price(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Получить цену NFT"""
    try:
        price = float(update.message.text)
        context.user_data['nft_price'] = price
        
        await update.message.reply_text(
            "📝 Хорошо!\n\n"
            "Введите описание NFT:"
        )
        return ENTERING_DESCRIPTION
    except ValueError:
        await update.message.reply_text(
            "❌ Ошибка! Введите числовое значение цены.\n\n"
            "Попробуйте снова:"
        )
        return ENTERING_PRICE

async def receive_nft_description(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Получить описание NFT и сохранить"""
    user_id = update.message.from_user.id
    
    nft_data = {
        'id': str(uuid.uuid4()),
        'name': context.user_data['nft_name'],
        'price': context.user_data['nft_price'],
        'description': update.message.text,
        'date': datetime.now().strftime("%d.%m.%Y %H:%M"),
        'owner_id': user_id
    }
    
    if user_id not in user_nfts:
        user_nfts[user_id] = []
    
    user_nfts[user_id].append(nft_data)
    
    keyboard = [
        [InlineKeyboardButton("🎨 Мои NFT", callback_data='my_nfts')],
        [InlineKeyboardButton("◀️ Главное меню", callback_data='back_to_menu')]
    ]
    
    await update.message.reply_text(
        f"✅ *NFT успешно добавлен!*\n\n"
        f"🎨 Название: {nft_data['name']}\n"
        f"💰 Цена: {nft_data['price']} TON\n"
        f"📝 Описание: {nft_data['description']}",
        reply_markup=InlineKeyboardMarkup(keyboard),
        parse_mode='Markdown'
    )
    
    # Очистка временных данных
    context.user_data.clear()
    
    return CHOOSING_ACTION

async def sell_nft(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Выставить NFT на продажу"""
    query = update.callback_query
    user_id = query.from_user.id
    
    nft_index = int(query.data.split('_')[1])
    
    if user_id not in user_nfts or nft_index >= len(user_nfts[user_id]):
        await query.answer("❌ NFT не найден!", show_alert=True)
        return CHOOSING_ACTION
    
    nft_data = user_nfts[user_id][nft_index]
    
    await query.edit_message_text(
        f"💼 *Продажа NFT*\n\n"
        f"🎨 {nft_data['name']}\n"
        f"💰 Цена: {nft_data['price']} TON\n\n"
        f"Для совершения сделки свяжитесь с поддержкой: @{SUPPORT_USERNAME}",
        reply_markup=InlineKeyboardMarkup([
            [InlineKeyboardButton("◀️ Назад", callback_data=f'nft_{nft_index}')]
        ]),
        parse_mode='Markdown'
    )
    return CHOOSING_ACTION

async def delete_nft(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Удалить NFT"""
    query = update.callback_query
    user_id = query.from_user.id
    
    nft_index = int(query.data.split('_')[1])
    
    if user_id not in user_nfts or nft_index >= len(user_nfts[user_id]):
        await query.answer("❌ NFT не найден!", show_alert=True)
        return CHOOSING_ACTION
    
    deleted_nft = user_nfts[user_id].pop(nft_index)
    
    await query.answer("✅ NFT удален!", show_alert=True)
    await query.edit_message_text(
        f"🗑 NFT '{deleted_nft['name']}' успешно удален.",
        reply_markup=InlineKeyboardMarkup([
            [InlineKeyboardButton("🎨 Мои NFT", callback_data='my_nfts')],
            [InlineKeyboardButton("◀️ Главное меню", callback_data='back_to_menu')]
        ])
    )
    return CHOOSING_ACTION

async def show_my_deals(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Показать сделки пользователя"""
    query = update.callback_query
    user_id = query.from_user.id
    
    if user_id not in user_deals or not user_deals[user_id]:
